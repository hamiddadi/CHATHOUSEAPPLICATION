{
  "extends": ["stylelint-config-standard"],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "variants",
          "responsive",
          "screen",
          "config"
        ]
      }
    ],
    "block-no-empty": true,
    "color-no-invalid-hex": true,
    "declaration-block-no-duplicate-properties": true,
    "no-descending-specificity": null,
    "no-empty-source": null
  },
  "ignoreFiles": ["node_modules/**", ".expo/**", "android/**", "ios/**", "dist/**", "coverage/**"]
}
