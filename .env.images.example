# Real photo URLs — public APIs, no key required.
# Append these to your .env / .env.local. For Expo, expose via app.json "extra".
# Consumed by src/shared/constants/images.ts (optional — see real_images_config.json integration guide).

# ---- Defaults ------------------------------------------------------------
DEFAULT_AVATAR_URL=https://randomuser.me/api/portraits/thumb/men/32.jpg
DEFAULT_AVATAR_LARGE_URL=https://randomuser.me/api/portraits/men/32.jpg
DEFAULT_COVER_URL=https://picsum.photos/seed/chathouse/800/400
DEFAULT_BANNER_URL=https://picsum.photos/seed/chathouse-banner/1080/480
DEFAULT_HOUSE_ICON_URL=https://picsum.photos/seed/chathouse-house/200/200
DEFAULT_BACKGROUND_URL=https://picsum.photos/seed/chathouse-bg/1080/1920
DEFAULT_ROOM_THUMB_URL=https://picsum.photos/seed/room-default/400/400

# ---- Base paths (for dynamic URL construction) --------------------------
AVATAR_BASE_URL=https://randomuser.me/api/portraits
AVATAR_THUMB_BASE_URL=https://randomuser.me/api/portraits/thumb
PICSUM_BASE_URL=https://picsum.photos/seed
UNSPLASH_BASE_URL=https://images.unsplash.com

# ---- Fallback AI-generated portrait (do NOT use at scale, single image per request) ----
FALLBACK_AI_PORTRAIT_URL=https://thispersondoesnotexist.com/image

# ---- 10 realistic avatars (5 men + 5 women) -----------------------------
AVATAR_MALE_01=https://randomuser.me/api/portraits/men/12.jpg
AVATAR_MALE_02=https://randomuser.me/api/portraits/men/32.jpg
AVATAR_MALE_03=https://randomuser.me/api/portraits/men/45.jpg
AVATAR_MALE_04=https://randomuser.me/api/portraits/men/67.jpg
AVATAR_MALE_05=https://randomuser.me/api/portraits/men/88.jpg
AVATAR_FEMALE_01=https://randomuser.me/api/portraits/women/5.jpg
AVATAR_FEMALE_02=https://randomuser.me/api/portraits/women/19.jpg
AVATAR_FEMALE_03=https://randomuser.me/api/portraits/women/33.jpg
AVATAR_FEMALE_04=https://randomuser.me/api/portraits/women/58.jpg
AVATAR_FEMALE_05=https://randomuser.me/api/portraits/women/77.jpg
