# Copy to .env.local and fill in values. .env.* files are gitignored.
API_BASE_URL=http://localhost:4000/api
WS_BASE_URL=ws://localhost:4000
REALTIME_ENABLED=true
ENV=development
SENTRY_DSN=

# ─── LiveKit (audio engine) ─────────────────────────────────────────────
# URL is the WebSocket endpoint of the LiveKit server.
# No secrets needed client-side — the backend signs JWT tokens.
# Run a local server: docker run -p 7880:7880 livekit/livekit-server --dev
LIVEKIT_URL=ws://localhost:7880

# ─── Google Maps (Android) ──────────────────────────────────────────────
# Required by react-native-maps to initialise the native MapView on Android
# (the Map screen overlays OSM tiles, but the Google SDK must be authorised or
# the Map tab crashes). Create a key in Google Cloud Console with "Maps SDK for
# Android" enabled, and restrict it to com.chathouse.app + your signing SHA-1.
GOOGLE_MAPS_API_KEY=
