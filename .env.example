# Copy to .env.local and fill in values. .env.* files are gitignored.
API_BASE_URL=http://localhost:4000/api
WS_BASE_URL=ws://localhost:4000
REALTIME_ENABLED=true
ENV=development
SENTRY_DSN=

# ─── Agora (audio engine) ──────────────────────────────────────────────
# Get these from https://console.agora.io after creating a project.
# AGORA_APP_ID is public; AGORA_TEMP_TOKEN is for dev only (max 24h TTL).
# Production should fetch a per-room token from /rooms/:id/agora-token
# (backend signs with AGORA_PRIMARY_CERTIFICATE — never ship that to client).
AGORA_APP_ID=
AGORA_CHANNEL_NAME=CHATHOUSE
AGORA_TEMP_TOKEN=
