{
  "name": "chathouse",
  "version": "0.1.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\" \"*.{json,md}\"",
    "stylelint": "stylelint \"**/*.css\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --passWithNoTests",
    "quality": "npm run lint -- --max-warnings 0 && npm run format:check && npm run typecheck",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@livekit/react-native": "^2.11.0",
    "@livekit/react-native-webrtc": "^144.1.0",
    "@notifee/react-native": "^9.1.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/geolocation": "^3.4.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-firebase/app": "^24.1.1",
    "@react-native-firebase/messaging": "^24.1.1",
    "@react-native-vector-icons/fontawesome": "^13.1.2",
    "@react-native-vector-icons/ionicons": "^13.1.2",
    "@react-native-vector-icons/material-icons": "^13.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.62.2",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "i18next": "^26.0.6",
    "libphonenumber-js": "^1.12.42",
    "nativewind": "^4.1.23",
    "react": "19.2.0",
    "react-hook-form": "^7.54.2",
    "react-i18next": "^17.0.4",
    "react-native": "0.83.6",
    "react-native-audio-recorder-player": "^3.6.14",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-haptic-feedback": "^2.3.4",
    "react-native-image-picker": "^8.2.1",
    "react-native-keychain": "^10.0.0",
    "react-native-localize": "^3.7.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "0.7.4",
    "socket.io-client": "^4.8.3",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@testing-library/react-native": "^13.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-native": "^4.1.0",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.11",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.0",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "*"
  }
}
