# ─────────────────────────────────────────────────────────────────────────────
# ChatHouse — PostgreSQL backup configuration (example).
#
# Copy to .env.backup and adjust. These vars are consumed by:
#   scripts/backup/pg_backup.sh, pg_restore.sh, test_backup.sh
#   docker/backup/Dockerfile + docker-compose.backup.yml
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL connection ────────────────────────────────────────────────────
# Inside Docker (compose override) use the service name "postgres" and the
# INTERNAL port 5432. From the host directly, use localhost and the mapped port
# 5433 (see docker-compose.yml: "5433:5432").
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=chathouse
POSTGRES_USER=chathouse
POSTGRES_PASSWORD=chathouse

# ── Local backup storage ─────────────────────────────────────────────────────
# Directory where backup_YYYYMMDD_HHMMSS.sql.gz files are written.
# In the container this is a mounted volume; defaults to /backups.
BACKUP_DIR=/backups

# Local backups older than this many days are deleted after each run
# (find -mtime +N -delete).
BACKUP_RETENTION_DAYS=7

# ── Cron schedule (container only) ───────────────────────────────────────────
# Standard 5-field cron expression. Default = 02:00 every day.
BACKUP_CRON_SCHEDULE=0 2 * * *

# Set to "true" to run one backup immediately when the container starts.
BACKUP_RUN_ON_START=false

# ── Optional offsite copy to Amazon S3 ───────────────────────────────────────
# Leave S3_BACKUP_BUCKET EMPTY to keep backups LOCAL ONLY (no upload attempted).
# When set, each dump is uploaded with: aws s3 cp <file> s3://<bucket>/<prefix>/
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=chathouse

# AWS credentials/region used by the aws-cli for S3 upload/list/download.
# Only required when S3_BACKUP_BUCKET is set. Prefer an IAM role in production.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
