# ─── Runtime ────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://chathouse:chathouse@localhost:5432/chathouse?schema=public

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (JWT) ─────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── CORS (comma-separated) ─────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://chathouse.app

# ─── Rate limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── OTP / SMS (Module 1) ───────────────────────────────
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_HOUR=5
# Fill these in production to use Twilio SMS instead of the dev logger.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─── Push (Module 6) ────────────────────────────────────
# Flip to true in production once a device can be reached. In dev the
# dispatcher just logs the payload.
PUSH_DISPATCH_ENABLED=false
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
# Optional — raises Expo's per-IP rate limit. Create at expo.dev → Access Tokens.
# EXPO_ACCESS_TOKEN=

# ─── Agora (audio engine token signing) ─────────────────
# APP_ID is public (shipped to clients). The CERTIFICATE is a SECRET
# used to sign per-room tokens — never expose it to client builds.
# Get both from https://console.agora.io after enabling certificates.
AGORA_APP_ID=
AGORA_PRIMARY_CERTIFICATE=
# Optional rolling key for zero-downtime certificate rotation.
AGORA_SECONDARY_CERTIFICATE=
# Token TTL in seconds. Clients renew ~30s before expiry; 1h is sane.
AGORA_TOKEN_TTL_SECONDS=3600
