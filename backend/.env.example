# ─── Runtime ────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://chathouse:chathouse@localhost:5432/chathouse?schema=public

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (JWT) ─────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── CORS (comma-separated) ─────────────────────────────
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://chathouse.app

# ─── Rate limiting ──────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─── OTP / SMS (Module 1) ───────────────────────────────
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_HOUR=5
# Dev/QA only (ignored when NODE_ENV=production): comma-separated phone numbers
# that skip the real SMS/OTP and log in with OTP_TEST_CODE. Matched by
# digit-suffix, so "550728585" also matches "+213550728585".
# OTP_TEST_NUMBERS=550728585
# OTP_TEST_CODE=000000
# Fill these in production to use Twilio SMS instead of the dev logger.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# ─── Push (Module 6) — Firebase Cloud Messaging ─────────
# Flip to true in production once a device can be reached. In dev the
# dispatcher just logs the payload.
PUSH_DISPATCH_ENABLED=false
# firebase-admin service-account credentials (Firebase console → Project
# settings → Service accounts → Generate new private key). Paste the JSON as a
# single line, or instead set GOOGLE_APPLICATION_CREDENTIALS to a file path.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"…"}
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json

# ─── LiveKit (audio engine token signing) ────────────────
# LIVEKIT_URL is the WebSocket endpoint of the LiveKit server.
# API_KEY and API_SECRET are used to sign per-room JWT tokens.
# The secret must NEVER be exposed to client builds.
# Run a local server: docker run -p 7880:7880 livekit/livekit-server --dev
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Token TTL in seconds. Clients renew ~30s before expiry; 1h is sane.
LIVEKIT_TOKEN_TTL_SECONDS=3600
