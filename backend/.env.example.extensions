# ───────────────────────────────────────────────────────────
# Supplement to .env.example — env vars for the 7 Vagues
# extensions layer (backend/src/extensions/*).
#
# All variables below are OPTIONAL. When unset, the corresponding
# extension endpoint degrades gracefully (returns PAY_NOT_CONFIGURED
# for payments/captions/twitter, falls back to defaults elsewhere).
# Copy any of these lines you need into your real `.env`.
# ───────────────────────────────────────────────────────────

# ─── Vague 1 — Contacts sync (privacy salt) ────────────
# Used to hash phone numbers client-side before sending to
# /api/ext/contacts/match. Regenerate with `openssl rand -hex 32`.
CONTACTS_HASH_SALT=change-me-32-byte-hex

# ─── Vague 7 — Stripe Connect (Creator payments) ────────
# Sign up at https://dashboard.stripe.com to get keys.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx
STRIPE_RETURN_URL=https://app.chathouse.com/payments/return
STRIPE_REFRESH_URL=https://app.chathouse.com/payments/refresh
# Once these are set, also run: `pnpm add stripe` in backend/

# ─── Vague 7 — Live captions (ASR provider) ─────────────
# Set provider to "whisper" or "deepgram" then add the corresponding key.
ASR_PROVIDER=whisper
ASR_API_KEY=sk-xxx

# ─── Vague 7 — Twitter / X OAuth import ─────────────────
# Create an app at https://developer.twitter.com/en/portal/projects
# Enable OAuth 2.0 PKCE with `chathouse://oauth/twitter` as redirect.
TWITTER_CLIENT_ID=xxx
TWITTER_CLIENT_SECRET=xxx
TWITTER_REDIRECT_URI=chathouse://oauth/twitter
