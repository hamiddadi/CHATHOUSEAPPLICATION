# ─────────────────────────────────────────────────────────────────────────────
# Chathouse — TLS-terminating reverse proxy (Caddy).
#
# Caddy provisions + renews Let's Encrypt certificates automatically, so the API
# and LiveKit are reachable over https:// and wss:// (required by iOS ATS and
# Android cleartext policy, and by the production env-guard in src/config/env.ts).
#
# DNS: point api.chathouse.app and livekit.chathouse.app A/AAAA records at this
# host, and open TCP 80+443 (Caddy) and the LiveKit UDP media range on the
# firewall. Set EMAIL for ACME expiry notices via the host .env.
#
# Brought up by the `caddy` service in docker-compose.prod.yml. Caddy reaches
# the other containers by their compose service name on the internal network,
# so api/livekit do NOT need to publish public host ports.
# ─────────────────────────────────────────────────────────────────────────────
{
	email {$ACME_EMAIL:admin@chathouse.app}
}

# Public REST + Socket.IO API. reverse_proxy transparently upgrades WebSocket
# (socket.io) connections, so wss://api.chathouse.app works with no extra config.
api.chathouse.app {
	encode zstd gzip
	reverse_proxy api:4000
}

# LiveKit signalling (wss). Media still flows over the UDP range opened on the
# firewall directly to the livekit container's published UDP ports.
livekit.chathouse.app {
	reverse_proxy livekit:7880
}
