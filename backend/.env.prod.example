# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION secrets for docker-compose.prod.yml.
# Copy to `.env` on the production host (NOT committed), `chmod 600`, fill in,
# and the compose file will fail loudly at boot if any required value is missing.
# Generate strong values, e.g.:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Postgres
POSTGRES_USER=chathouse
POSTGRES_PASSWORD=__CHANGE_ME__strong-random__
POSTGRES_DB=chathouse

# Redis (AUTH is enforced in prod)
REDIS_PASSWORD=__CHANGE_ME__strong-random__

# JWT signing (min 32 chars each — backend env.ts rejects shorter)
JWT_ACCESS_SECRET=__CHANGE_ME__at-least-32-characters-long__
JWT_REFRESH_SECRET=__CHANGE_ME__at-least-32-characters-long__

# CORS — the public origins of the mobile app / web client
CORS_ORIGINS=https://app.chathouse.app

# ─── LiveKit (REQUIRED — live audio returns 503 without it) ───
# LiveKit Cloud (recommended): create a project, copy its values.
# Self-host: LIVEKIT_URL = wss://livekit.chathouse.app (the `livekit` service
# behind your TLS proxy), key/secret must match the LIVEKIT_KEYS env there.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=__CHANGE_ME__
LIVEKIT_API_SECRET=__CHANGE_ME__
LIVEKIT_TOKEN_TTL_SECONDS=3600

# TLS reverse proxy (Caddy) — email for Let's Encrypt expiry notices
ACME_EMAIL=admin@chathouse.app

# ─── Observability (optional) ───
SENTRY_DSN=
# Bearer token that gates GET /metrics in prod (leave empty to keep it open
# only on the loopback interface behind your proxy).
METRICS_TOKEN=

# Set by the CD pipeline at deploy time — no need to fill manually.
# CHATHOUSE_API_IMAGE=ghcr.io/<owner>/chathouse/api:1.0.0
