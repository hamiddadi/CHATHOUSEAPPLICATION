# OS
.DS_Store
Thumbs.db

# Node
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native
ios/
# android/ is now a committed, hand-maintained bare React Native project (de-Expo
# migration). Build artifacts under it stay ignored via android/.gitignore and the
# generic `build/` rule below. Only source + gradle wrapper + debug.keystore commit.
*.jks
*.keystore
# debug.keystore is intentionally committed (shared debug signing); the rule
# above would otherwise catch it.
!android/app/debug.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# Env
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Logs
*.log

# Tests
coverage/

# Build
build/

# Build artifacts: prebuilt APKs are large binaries that bloat the repo and
# stall HTTP pushes — keep them on disk but out of git. Produce via gradle.
*.apk

# Uploaded media (avatars) — created at runtime by the backend upload module;
# the files are environment-specific and must not be versioned. The directory
# is mkdir'd on first write (backend/src/modules/upload/upload.service.ts).
backend/uploads/

# Firebase (carries project API key) — provided locally / via CI secret, not
# committed. Match any location so a stray copy can't slip in.
google-services.json
