{
  "expo": {
    "name": "Chathouse",
    "slug": "chathouse",
    "version": "1.0.0",
    "runtimeVersion": { "policy": "appVersion" },
    "orientation": "portrait",
    "scheme": "chathouse",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c112e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chathouse.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Chathouse uses your microphone so you can speak in audio rooms and record voice messages.",
        "NSCameraUsageDescription": "Chathouse uses the camera so you can update your profile photo.",
        "NSPhotoLibraryUsageDescription": "Chathouse needs access to your photos so you can update your profile photo.",
        "NSLocationWhenInUseUsageDescription": "Chathouse shows friends and rooms on the map when you allow location access.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0c112e"
      },
      "package": "com.chathouse.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "MODIFY_AUDIO_SETTINGS",
        "ACCESS_NETWORK_STATE",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT"
      ],
      "blockedPermissions": ["android.permission.SYSTEM_ALERT_WINDOW"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-localization",
      "@sentry/react-native",
      [
        "expo-image-picker",
        {
          "photosPermission": "Chathouse needs photo access to update your profile photo."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Chathouse shows nearby rooms on the map when you allow location access.",
          "isAndroidBackgroundLocationEnabled": false,
          "isAndroidForegroundServiceEnabled": false
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
